{
  "name": "selecaoglobocom/jonatan-reginatoo",
  "description": "Aplicacao do tipo BFF (backend for frontend) responsavel por prover dados para que seus clientes possam montar uma pagina de calendario de jogos de futebol do ano de 2019.",
  "type": "project",
  "license": "proprietary",
  "keywords": [
    "globo",
    "g1",
    "ge",
    "bff",
    "laminas",
    "mezzio",
    "middleware",
    "psr",
    "psr-7",
    "psr-11",
    "psr-15"
  ],
  "homepage": "https://github.com/SelecaoGlobocom/jonatan-reginatoo",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "bin-dir": "bin/",
    "sort-packages": true
  },
  "extra": {
    "laminas": {
      "component-whitelist": [
        "laminas/laminas-config-aggregator",
        "laminas/laminas-diactoros",
        "laminas/laminas-httphandlerrunner",
        "laminas/laminas-servicemanager",
        "laminas/laminas-stratigility",
        "mezzio/mezzio",
        "mezzio/mezzio-fastroute",
        "mezzio/mezzio-helpers",
        "mezzio/mezzio-platesrenderer",
        "mezzio/mezzio-router"
      ]
    }
  },
  "require": {
    "php": "^7.4",
    "ext-json": "*",
    "ext-newrelic": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "ext-xmlwriter": "*",
    "aws/aws-sdk-php": "^3.158",
    "beberlei/assert": "^3.2",
    "broadway/broadway": "^2.3",
    "bugsnag/bugsnag": "^3.23",
    "fig/http-message-util": "^1.1",
    "jsq/amazon-es-php": "^0.3.0",
    "laminas/laminas-config-aggregator": "^1.3",
    "laminas/laminas-diactoros": "^2.4",
    "laminas/laminas-httphandlerrunner": "^1.2",
    "laminas/laminas-servicemanager": "^3.4",
    "laminas/laminas-stratigility": "^3.2",
    "lcobucci/jwt": "^3.3",
    "mezzio/mezzio": "^3.2",
    "mezzio/mezzio-fastroute": "^3.0",
    "mezzio/mezzio-helpers": "^5.3",
    "mezzio/mezzio-platesrenderer": "^2.2",
    "mezzio/mezzio-router": "^3.1",
    "monolog/monolog": "^2.1",
    "php-middleware/request-id": "^4.0",
    "predis/predis": "^1.1",
    "psr/cache": "^1.0.1",
    "psr/container": "^1.0.0",
    "psr/http-factory": "^1.0.1",
    "psr/http-message": "^1.0.1",
    "psr/http-server-handler": "^1.0.1",
    "psr/http-server-middleware": "^1.0.1",
    "psr/log": "^1.1.3",
    "psr/simple-cache": "^1.0.1",
    "ramsey/uuid": "^4.1",
    "respect/validation": "^2.1",
    "symfony/console": "5.1",
    "tuupola/cors-middleware": "^1.2",
    "tuupola/slim-jwt-auth": "^3.5",
    "vlucas/phpdotenv": "^4.1",
    "zircote/swagger-php": "^3.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^2.16",
    "phpunit/phpunit": "^8.5",
    "roave/security-advisories": "dev-master",
    "squizlabs/php_codesniffer": "^3.5",
    "symfony/var-dumper": "^5.1"
  },
  "autoload": {
    "psr-4": {
      "SelecaoGlobo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SelecaoGlobo\\": "test/"
    },
    "classmap": [
      "test/"
    ]
  },
  "scripts": {
    "check": [
      "@cs-check",
      "@test"
    ],
    "clear-config-cache": "php bin/clear-config-cache.php",
    "cs-check": "./bin/phpcs -w -p",
    "cs-fix": "./bin/phpcbf",
    "test": "./bin/phpunit --configuration phpunit.xml",
    "test-unit": "./bin/phpunit --configuration phpunit.xml --testsuite unit-tests",
    "test-unit-coverage": "./bin/phpunit --configuration phpunit.xml --testsuite unit-tests --coverage-html public/coverage/unit --coverage-clover target/unit/coverage.xml --coverage-text='target/unit/coverage.txt' --log-junit target/unit/report.xml",
    "test-unit-domain": "./bin/phpunit --configuration phpunit.xml --testsuite unit-tests-domain",
    "test-unit-domain-coverage": "./bin/phpunit --configuration phpunit.xml --testsuite unit-tests-domain --coverage-html public/coverage/unit --coverage-clover target/unit/coverage.xml --coverage-text='target/unit/coverage.txt' --log-junit target/unit/report.xml",
    "test-integration": "./bin/phpunit --configuration phpunit.xml --testsuite integration-tests",
    "test-integration-coverage": "./bin/phpunit --configuration phpunit.xml --testsuite integration-tests --coverage-html public/coverage/integration --coverage-clover target/integration/coverage.xml --coverage-text='target/integration/coverage.txt' --log-junit target/integration/report.xml",
    "test-integration-domain": "./bin/phpunit --configuration phpunit.xml --testsuite integration-tests-domain",
    "test-integration-domain-coverage": "./bin/phpunit --configuration phpunit.xml --testsuite integration-tests-domain --coverage-html public/coverage/integration --coverage-clover target/integration/coverage.xml --coverage-text='target/integration/coverage.txt' --log-junit target/integration/report.xml"
  }
}
